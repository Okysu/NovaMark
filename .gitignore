# ============================================================
# C / C++ .gitignore
# Covers: GCC / Clang / MSVC builds, CMake, vcpkg, common IDEs
# ============================================================

# ----------------------------------------------------------
# Compiled object files
# ----------------------------------------------------------
*.o
*.obj
*.lo
*.slo
*.ko

# ----------------------------------------------------------
# Precompiled headers
# ----------------------------------------------------------
*.gch
*.pch

# ----------------------------------------------------------
# Static / shared libraries
# ----------------------------------------------------------
*.a
*.la
*.lai
*.lib
*.so
*.so.*
*.dll
*.dylib

# ----------------------------------------------------------
# Executables
# ----------------------------------------------------------
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex
*.elf

# ----------------------------------------------------------
# Debug / profiling artifacts
# ----------------------------------------------------------
*.dSYM/
*.su
*.idb
*.pdb
*.ilk
*.exp
*.map
*.pgd
*.pgc
*.gcno
*.gcda
gmon.out
core
core.*

# ----------------------------------------------------------
# Build-time caches (clangd index, CMake API cache, etc.)
# ----------------------------------------------------------
.cache/
.cmake/

# CTest / CDash temporary results (root-level and in build/)
Testing/

# ----------------------------------------------------------
# CMake
# ----------------------------------------------------------
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
_deps/
Makefile                 # generated by CMake (keep your own if hand-written)
compile_commands.json    # can also be committed; remove this line if you want it

# Common out-of-source build directories
build/
build-*/
cmake-build-*/
out/
release/
debug/
dist/

# ----------------------------------------------------------
# vcpkg
# ----------------------------------------------------------
# Installed packages and build trees managed by vcpkg
vcpkg_installed/

# Manifest mode install log (generated on every cmake configure)
vcpkg-manifest-install.log

# Classic (non-manifest) mode: the full vcpkg tree is external —
# only the toolchain file reference lives in CMakeLists.txt.
# Manifest mode: vcpkg.json is intentionally tracked; only the
# generated install dir below should be ignored.
# vcpkg/              # un-comment if vcpkg is vendored as a subdirectory

# vcpkg buildtrees / downloads (only relevant if vcpkg root is inside the repo)
vcpkg/buildtrees/
vcpkg/downloads/
vcpkg/packages/
vcpkg/installed/

# ----------------------------------------------------------
# Make / Autotools
# ----------------------------------------------------------
*.d
.deps/
.libs/
autom4te.cache/
config.log
config.status
configure~
Makefile.in
aclocal.m4
ltmain.sh
stamp-h1

# ----------------------------------------------------------
# Ninja
# ----------------------------------------------------------
.ninja_deps
.ninja_log
build.ninja

# ----------------------------------------------------------
# Conan (optional — remove block if not used)
# ----------------------------------------------------------
conanbuildinfo.*
conaninfo.txt
graph_info.json
conan.lock

# ----------------------------------------------------------
# Visual Studio / MSVC
# ----------------------------------------------------------
.vs/
*.VC.db
*.VC.opendb
*.vcxproj.user
*.vcxproj.filters   # optional: commit if your team shares filter layout
ipch/
*.ipch
*.ncb
*.opensdf
*.sdf
*.aps

# ----------------------------------------------------------
# VS Code
# ----------------------------------------------------------
.vscode/
# Un-comment the lines below to keep shared settings:
# !.vscode/settings.json
# !.vscode/tasks.json
# !.vscode/launch.json
# !.vscode/extensions.json
# !.vscode/c_cpp_properties.json

# ----------------------------------------------------------
# CLion / JetBrains
# ----------------------------------------------------------
.idea/
cmake-build-*/
*.iml

# ----------------------------------------------------------
# Xcode
# ----------------------------------------------------------
*.xcodeproj/
*.xcworkspace/
DerivedData/
*.moved-aside
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
*.xccheckout
*.xcscmblueprint

# ----------------------------------------------------------
# Eclipse CDT
# ----------------------------------------------------------
.cproject
.project
.settings/

# ----------------------------------------------------------
# Qt Creator
# ----------------------------------------------------------
*.pro.user
*.pro.user.*
*.qbs.user
*.qbs.user.*
*.moc
moc_*.cpp
moc_*.h
qrc_*.cpp
ui_*.h

# ----------------------------------------------------------
# Emacs / Vim / misc editors
# ----------------------------------------------------------
*~
\#*\#
.#*
*.swp
*.swo
*.bak
.DS_Store
Thumbs.db