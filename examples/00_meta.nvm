base_audio_path: assets/audio/
---

@char 沈砚
  color: #8EC5FF
  description: 在港城旧书店兼职的青年，习惯把事情记在心里。
  sprite_default: shenyan_normal.png
  sprite_pensive: shenyan_pensive.png
  sprite_determined: shenyan_determined.png
@end

@char 祁星
  color: #FFD36E
  description: 总在关键时刻出现的少女，像知道很多不该知道的事。
  sprite_default: qixing_normal.png
  sprite_mysterious: qixing_mysterious.png
  sprite_gentle: qixing_gentle.png
@end

@char 馆长
  color: #C7A6FF
  description: 潮汐图书馆的管理者，说话缓慢而准确。
  sprite_default: curator_normal.png
  sprite_solemn: curator_solemn.png
@end

@item brass_key
  name: 黄铜钥匙
  description: 雨夜书店抽屉里找到的旧钥匙，钥匙柄刻着波浪纹。
@end

@item tide_map
  name: 潮汐地图
  description: 会随着选择改变内容的海图，边角仍带着盐粒。
@end

@item blue_postcard
  name: 蓝色明信片
  description: 一张没有邮戳的明信片，背面写着“别让灯灭掉”。
@end

@var trust = 0
@var courage = 0
@var memory = 0
@var visited_annex = 0
@var listened_bell = 0
@var promise = 0
