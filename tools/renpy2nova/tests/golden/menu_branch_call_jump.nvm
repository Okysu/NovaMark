@var affinity = true

@var seen_side = null

#scene_start "start"
> 你想做什么？
? 请选择路线
- [前往主线] -> scene_main_route if affinity == true
- [查看支线] if seen_side == null
    @call scene_side_story
@return

#scene_main_route "main_route"
if affinity == true
    @set affinity = false
else
    @set seen_side = true
endif
> 你进入了主线。
@return

#scene_side_story "side_story"
@sfx branch.wav
> 这里是支线。
@return
